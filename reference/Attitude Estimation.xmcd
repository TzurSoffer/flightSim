		</region>
		<region region-id="106" left="18" top="779.25" width="155.25" height="57" align-x="56.25" align-y="810" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:function>
						<ml:id xml:space="preserve" subscript="ω">M</ml:id>
						<ml:boundVars>
							<ml:id xml:space="preserve">dt</ml:id>
						</ml:boundVars>
					</ml:function>
					<ml:matrix rows="3" cols="3">
						<ml:real>1</ml:real>
						<ml:apply>
							<ml:mult/>
							<ml:id xml:space="preserve" subscript="z">ω</ml:id>
							<ml:id xml:space="preserve">dt</ml:id>
						</ml:apply>
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:neg/>
								<ml:id xml:space="preserve" subscript="y">ω</ml:id>
							</ml:apply>
							<ml:id xml:space="preserve">dt</ml:id>
						</ml:apply>
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:neg/>
								<ml:id xml:space="preserve" subscript="z">ω</ml:id>
							</ml:apply>
							<ml:id xml:space="preserve">dt</ml:id>
						</ml:apply>
						<ml:real>1</ml:real>
						<ml:apply>
							<ml:mult/>
							<ml:id xml:space="preserve" subscript="x">ω</ml:id>
							<ml:id xml:space="preserve">dt</ml:id>
						</ml:apply>
						<ml:apply>
							<ml:mult/>
							<ml:id xml:space="preserve" subscript="y">ω</ml:id>
							<ml:id xml:space="preserve">dt</ml:id>
						</ml:apply>
						<ml:apply>
							<ml:mult/>
							<ml:apply>
								<ml:neg/>
								<ml:id xml:space="preserve" subscript="x">ω</ml:id>
							</ml:apply>
							<ml:id xml:space="preserve">dt</ml:id>
						</ml:apply>
						<ml:real>1</ml:real>
					</ml:matrix>
				</ml:define>
			</math>
