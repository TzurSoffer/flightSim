		<region region-id="144" left="102" top="956.25" width="104.25" height="12" align-x="102" align-y="966" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="false">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Init value of State-Matrix</p>
			</text>
		</region>
		<region region-id="110" left="6" top="1010.25" width="160.5" height="12" align-x="6" align-y="1020" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<b>
						<u>Integration (of angular velocities):</u>
					</b>
				</p>
			</text>
		</region>
		<region region-id="111" left="6" top="1035" width="141.75" height="45.75" align-x="72" align-y="1044" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:function>
						<ml:id xml:space="preserve">ROT</ml:id>
						<ml:boundVars>
							<ml:id xml:space="preserve">R</ml:id>
							<ml:id xml:space="preserve">W</ml:id>
							<ml:id xml:space="preserve">N</ml:id>
						</ml:boundVars>
					</ml:function>
					<ml:program>
						<ml:for>
							<ml:id xml:space="preserve">i</ml:id>
							<ml:range>
								<ml:real>0</ml:real>
								<ml:id xml:space="preserve">N</ml:id>
							</ml:range>
							<ml:localDefine>
								<ml:id xml:space="preserve">R</ml:id>
								<ml:apply>
									<ml:mult/>
									<ml:id xml:space="preserve">R</ml:id>
									<ml:id xml:space="preserve">W</ml:id>
								</ml:apply>
							</ml:localDefine>
						</ml:for>
						<ml:return>
							<ml:id xml:space="preserve">R</ml:id>
						</ml:return>
					</ml:program>
				</ml:define>
			</math>
			<rendering item-idref="13"/>
		</region>
		<region region-id="145" left="186" top="1034.25" width="125.25" height="36" align-x="186" align-y="1044" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="false">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">R is the State-Matrix.</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">W is the Delta-Matrix.</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">N is the number of iterations.</p>
			</text>
		</region>
		<region region-id="112" left="12" top="1112.25" width="32.25" height="12" align-x="12" align-y="1122" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<b>
						<u>Result:</u>
					</b>
				</p>
			</text>
		</region>
		<region region-id="149" left="12" top="1131" width="219.75" height="16.5" align-x="135" align-y="1140" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:eval placeholderMultiplicationStyle="default" xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:apply>
						<ml:mult/>
						<ml:id xml:space="preserve">A</ml:id>
						<ml:apply>
							<ml:id xml:space="preserve">ROT</ml:id>
							<ml:sequence>
								<ml:id xml:space="preserve" subscript="R">DCM</ml:id>
								<ml:apply>
									<ml:id xml:space="preserve" subscript="ω">M</ml:id>
									<ml:real>0.1</ml:real>
								</ml:apply>
								<ml:real>10</ml:real>
							</ml:sequence>
						</ml:apply>
					</ml:apply>
					<result xmlns="http://schemas.mathsoft.com/math30">
						<ml:matrix rows="1" cols="3">
							<ml:real>-11.091420737731088</ml:real>
							<ml:real>0</ml:real>
							<ml:real>-1.5978246064051835</ml:real>
						</ml:matrix>
					</result>
				</ml:eval>
			</math>
			<rendering item-idref="14"/>
		</region>
		<region region-id="153" left="252" top="1130.25" width="217.5" height="60" align-x="252" align-y="1140" show-border="true" show-highlight="true" is-protected="true" z-order="0" background-color="#0f0" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<b>Notice that as 'dt' becomes smaller the accuracy increases, even with constant omega values.</b>
				</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<b>This isn't a bandwidth issue. Is it a numerical approximation problem.</b>
				</p>
			</text>
		</region>
		<region region-id="147" left="12" top="1161" width="224.25" height="16.5" align-x="144" align-y="1170" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
